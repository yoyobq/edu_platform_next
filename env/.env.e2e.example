# 留空时，Playwright 会自己启动一份 Vite 服务。
PLAYWRIGHT_BASE_URL=

# E2E 运行时注入到应用内部的环境标识。
PLAYWRIGHT_APP_ENV=test

# Playwright 管理的 Vite 所使用的 loopback 地址。
# 这个仓库当前默认使用 ::1，因为这台 WSL 机器上，
# 对空的 127.0.0.1:<port> 探测可能会在 Playwright 启动服务前卡住。
# 如果你的机器对 127.0.0.1 表现正常，且代理绕过配置也正确，
# 可以改回 127.0.0.1。
PLAYWRIGHT_HOST=::1
# PLAYWRIGHT_HOST=127.0.0.1

# Playwright 就绪探测时需要绕过代理的主机列表。
# 如果你修改了上面的 loopback 地址，这里也要一起调整。
PLAYWRIGHT_NO_PROXY_APPEND=localhost,127.0.0.1,::1,[::1]

PLAYWRIGHT_PORT=42173

# E2E 运行时注入到应用内部的 API 地址。
VITE_GRAPHQL_ENDPOINT=https://api.example.com/graphql
VITE_API_HEALTH_ENDPOINT=https://api.example.com/health
VITE_API_READINESS_ENDPOINT=https://api.example.com/health/readiness
